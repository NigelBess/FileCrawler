<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileCrawler.ViewModels"
        xmlns:views="using:FileCrawler.Views"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="620"
        x:Class="FileCrawler.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-icon.ico"
        Width="1000" Height="620"
        WindowState="Maximized"
        Title="FileCrawler — Fast File Search">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>

        <!-- Top menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="FileCrawler">
                <MenuItem Header="Settings…"
                          Command="{Binding OpenSettingsCommand}"
                          ToolTip.Tip="Configure crawl behavior">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Cog" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Reset"
                          Command="{Binding ResetCommand}"
                          IsEnabled="{Binding !IsBusy}"
                          ToolTip.Tip="Clear everything and restore the standard folders">
                    <MenuItem.Icon>
                        <mi:MaterialIcon Kind="Restore" Width="16" Height="16"/>
                    </MenuItem.Icon>
                </MenuItem>
            </MenuItem>
        </Menu>

        <Grid ColumnDefinitions="Auto,*">

        <!-- Left: watched folders (collapsible, collapsed by default) -->
        <DockPanel Grid.Column="0" Width="300"
                   IsVisible="{Binding IsSidebarExpanded}"
                   Background="{DynamicResource SystemControlBackgroundListLowBrush}">
            <Grid DockPanel.Dock="Top" Margin="12,12,12,6" ColumnDefinitions="*,Auto">
                <SelectableTextBlock Grid.Column="0" Text="Watched Folders" FontWeight="SemiBold" FontSize="15"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Padding="6,4"
                        ToolTip.Tip="Refresh all folders"
                        Command="{Binding RefreshAllCommand}"
                        IsEnabled="{Binding !IsBusy}">
                    <mi:MaterialIcon Kind="Refresh" Width="18" Height="18"/>
                </Button>
            </Grid>

            <!-- Add folder pinned to the bottom of the list -->
            <Button DockPanel.Dock="Bottom" Margin="12,6,12,12"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Command="{Binding AddFolderCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <mi:MaterialIcon Kind="FolderPlusOutline" Width="18" Height="18"/>
                    <TextBlock Text="Add folder…" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <SelectableTextBlock DockPanel.Dock="Bottom" Margin="12,6,12,4" FontSize="11"
                       Foreground="Gray" TextWrapping="Wrap"
                       IsVisible="{Binding !WatchedFolders.Count}"
                       Text="No folders yet. Add a folder to crawl and search it."/>

            <ListBox ItemsSource="{Binding WatchedFolders}" Margin="6,0,6,0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WatchedFolderViewModel">
                        <Border Padding="6" CornerRadius="4">
                            <StackPanel Spacing="2">
                                <Grid ColumnDefinitions="*,Auto">
                                    <SelectableTextBlock Grid.Column="0" Text="{Binding DisplayName}" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                               ToolTip.Tip="{Binding Path}"/>
                                    <Button Grid.Column="1" Padding="6,2" Margin="4,0,0,0"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTip.Tip="Remove"
                                            Click="OnRemoveFolder">
                                        <mi:MaterialIcon Kind="TrashCanOutline" Width="15" Height="15"/>
                                    </Button>
                                </Grid>
                                <SelectableTextBlock Text="{Binding Path}" FontSize="10" Foreground="Gray"
                                           TextTrimming="CharacterEllipsis"/>
                                <WrapPanel Margin="0,2,0,0" IsVisible="{Binding !IsMissing}">
                                    <SelectableTextBlock Text="{Binding FormattedSize}" FontSize="11" Foreground="Gray"
                                               Margin="0,0,8,0"/>
                                    <SelectableTextBlock Text="{Binding FormattedItemCount}" FontSize="11" Foreground="Gray"
                                               Margin="0,0,8,0"/>
                                    <SelectableTextBlock Text="{Binding FormattedLoadTime}" FontSize="11" Foreground="Gray"
                                               Margin="0,0,8,0"/>
                                    <SelectableTextBlock Text="{Binding Status}" FontSize="11" Foreground="#3B82F6"/>
                                </WrapPanel>

                                <!-- Folder missing on disk: warn (in amber) and offer a one-click remove instead
                                     of silently showing a 0-byte, 0-item crawl. -->
                                <Border Margin="0,4,0,0" Padding="6,4" CornerRadius="4"
                                        Background="#33F59E0B" BorderBrush="#F59E0B" BorderThickness="1"
                                        IsVisible="{Binding IsMissing}">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <mi:MaterialIcon Grid.Column="0" Kind="AlertOutline"
                                                         Width="15" Height="15" Foreground="#B45309"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Grid.Column="1" Text="Path not found" FontSize="11"
                                                   Foreground="#B45309" VerticalAlignment="Center"
                                                   TextWrapping="Wrap"/>
                                        <Button Grid.Column="2" Padding="6,1" Margin="6,0,0,0"
                                                Background="Transparent" BorderThickness="1" BorderBrush="#B45309"
                                                Foreground="#B45309"
                                                ToolTip.Tip="Remove this watched folder"
                                                Click="OnRemoveFolder">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="TrashCanOutline" Width="13" Height="13"/>
                                                <TextBlock Text="Delete" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Crawl hit the time limit: warn (amber, mirroring the path-not-found warning)
                                     that results are partial, and offer a one-click block of the largest subfolder
                                     to let a re-crawl finish. Never shown for a missing folder. -->
                                <Border Margin="0,4,0,0" Padding="6,4" CornerRadius="4"
                                        Background="#33F59E0B" BorderBrush="#F59E0B" BorderThickness="1"
                                        IsVisible="{Binding IsIncomplete}">
                                    <StackPanel Spacing="4">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <mi:MaterialIcon Grid.Column="0" Kind="AlertOutline"
                                                             Width="15" Height="15" Foreground="#B45309"
                                                             VerticalAlignment="Top" Margin="0,1,6,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Crawl timed out — results may be incomplete. Block a large subfolder to let it finish, or raise the limit in Settings."
                                                       FontSize="11" Foreground="#B45309" TextWrapping="Wrap"/>
                                        </Grid>
                                        <Button Padding="6,2" HorizontalAlignment="Left"
                                                Background="Transparent" BorderThickness="1" BorderBrush="#B45309"
                                                Foreground="#B45309"
                                                IsVisible="{Binding SuggestedBlockPath, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                ToolTip.Tip="{Binding SuggestedBlockPath}"
                                                Click="OnBlockSuggestedSubfolder">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <mi:MaterialIcon Kind="Octagon" Width="13" Height="13"
                                                                 VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding BlockSuggestionLabel}" FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <!-- Blocked subfolders nested under their watched folder, in red -->
                                <ItemsControl ItemsSource="{Binding BlockedSubfolders}"
                                              Margin="10,4,0,0"
                                              IsVisible="{Binding BlockedSubfolders.Count}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:BlockedFolderViewModel">
                                            <views:BlockedFolderChip Margin="0,1" HorizontalAlignment="Left"
                                                                     RemoveRequested="OnUnblockFolder"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Add a subfolder to block (normal color; only actual blocks show red) -->
                                <Button Padding="6,2"
                                        Margin="10,4,0,0" HorizontalAlignment="Left"
                                        Background="Transparent" BorderThickness="0"
                                        IsVisible="{Binding !IsMissing}"
                                        ToolTip.Tip="Choose a subfolder to exclude from results"
                                        Click="OnAddBlockedFolder">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <mi:MaterialIcon Kind="Octagon" Width="14" Height="14"
                                                         VerticalAlignment="Center"/>
                                        <TextBlock Text="Block subfolder" FontSize="11"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Right: search + results -->
        <DockPanel Grid.Column="1" Margin="12">
            <DockPanel DockPanel.Dock="Top">
                <ToggleButton DockPanel.Dock="Left" Margin="0,0,8,0" Padding="10,6"
                              VerticalAlignment="Stretch"
                              IsChecked="{Binding IsSidebarExpanded}"
                              ToolTip.Tip="Toggle watched folders">
                    <mi:MaterialIcon Kind="FolderOutline" Width="18" Height="18"/>
                </ToggleButton>
                <TextBox PlaceholderText="Search files and folders…"
                         FontSize="16" Text="{Binding SearchText}"/>
            </DockPanel>

            <Expander DockPanel.Dock="Top" Margin="0,8,0,0" MinHeight="0"
                      HorizontalAlignment="Stretch"
                      IsExpanded="{Binding Filters.IsExpanded}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <mi:MaterialIcon Kind="FilterOutline" Width="16" Height="16"
                                         VerticalAlignment="Center" ToolTip.Tip="Filters"/>
                        <TextBlock Text="{Binding Filters.ActiveSummary}" Foreground="#3B82F6"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Expander.Header>

                <StackPanel Spacing="10" Margin="4">
                    <!-- Type allowlist: Select all / none apply to Folders plus every file-type category. -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SelectableTextBlock Text="Include:" VerticalAlignment="Center"/>
                        <Button Content="Select all" Padding="10,3" Command="{Binding Filters.SelectAllCommand}"/>
                        <Button Content="Select none" Padding="10,3" Command="{Binding Filters.SelectNoneCommand}"/>
                    </StackPanel>

                    <!-- Folders is its own axis; each file-type category keeps its per-extension flyout. -->
                    <WrapPanel>
                        <CheckBox Content="Folders" Margin="0,0,14,4"
                                  IsChecked="{Binding Filters.IncludeFolders}"/>
                        <ItemsControl ItemsSource="{Binding Filters.Categories}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:FileCategoryViewModel">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                                        <CheckBox Content="{Binding Name}" IsThreeState="False"
                                                  IsChecked="{Binding IsChecked}"/>
                                        <Button Padding="5,6" Margin="2,0,0,0"
                                                Background="Transparent" VerticalAlignment="Center"
                                                ToolTip.Tip="Choose specific extensions">
                                            <Path Data="M 0 0 L 8 0 L 4 5 Z" Fill="Gray"
                                                  VerticalAlignment="Center"/>
                                            <Button.Flyout>
                                                <Flyout>
                                                    <ScrollViewer MaxHeight="240">
                                                        <ItemsControl ItemsSource="{Binding Extensions}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="vm:ExtensionOptionViewModel">
                                                                    <CheckBox Content="{Binding Name}"
                                                                              IsChecked="{Binding IsSelected}"/>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </ScrollViewer>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </WrapPanel>

                    <!-- Custom extensions -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SelectableTextBlock Text="Other extensions:" VerticalAlignment="Center"/>
                        <TextBox Width="220" PlaceholderText=".psd .blend …"
                                 Text="{Binding Filters.CustomExtensionsText}"/>
                    </StackPanel>

                    <!-- Size / date / clear -->
                    <WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,20,4">
                            <SelectableTextBlock Text="Size:" VerticalAlignment="Center"/>
                            <TextBox Width="70" PlaceholderText="min" Text="{Binding Filters.MinSizeText}"/>
                            <ComboBox ItemsSource="{x:Static vm:SearchFiltersViewModel.SizeUnits}"
                                      SelectedItem="{Binding Filters.MinSizeUnit}"/>
                            <SelectableTextBlock Text="–" VerticalAlignment="Center"/>
                            <TextBox Width="70" PlaceholderText="max" Text="{Binding Filters.MaxSizeText}"/>
                            <ComboBox ItemsSource="{x:Static vm:SearchFiltersViewModel.SizeUnits}"
                                      SelectedItem="{Binding Filters.MaxSizeUnit}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,20,4">
                            <SelectableTextBlock Text="Modified:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{x:Static vm:SearchFiltersViewModel.DatePresetOptions}"
                                      SelectedItem="{Binding Filters.SelectedDatePreset}"/>
                            <CalendarDatePicker SelectedDate="{Binding Filters.CustomFromDate}"
                                                PlaceholderText="from" IsVisible="{Binding Filters.IsCustomDate}"/>
                            <CalendarDatePicker SelectedDate="{Binding Filters.CustomToDate}"
                                                PlaceholderText="to" IsVisible="{Binding Filters.IsCustomDate}"/>
                        </StackPanel>
                        <Button Command="{Binding Filters.ClearFiltersCommand}"
                                ToolTip.Tip="Clear filters"
                                IsEnabled="{Binding Filters.HasActiveFilters}">
                            <mi:MaterialIcon Kind="FilterRemoveOutline" Width="16" Height="16"/>
                        </Button>
                    </WrapPanel>

                    <SelectableTextBlock Text="{Binding Filters.ValidationMessage}" Foreground="#DC2626" FontSize="11"
                               IsVisible="{Binding Filters.ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                    <!-- Folders blocked from this search only (right-click a result → Block subfolder → From this
                         search). Each is removable with its own X; unlike watched-folder blocks these never recrawl. -->
                    <StackPanel Spacing="4" IsVisible="{Binding Filters.SearchBlockedFolders.Count}">
                        <SelectableTextBlock Text="Blocked from this search:" FontSize="11" Foreground="Gray"/>
                        <ItemsControl ItemsSource="{Binding Filters.SearchBlockedFolders}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:BlockedFolderViewModel">
                                    <views:BlockedFolderChip Margin="0,1" HorizontalAlignment="Left"
                                                             RemoveRequested="OnRemoveSearchBlock"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <Grid DockPanel.Dock="Top" Margin="2,8,2,8" ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <SelectableTextBlock Text="{Binding ResultsSummary}" Foreground="Gray"/>
                    <SelectableTextBlock Text="{Binding BlockedSummary}" Foreground="#DC2626" FontSize="11"
                               TextWrapping="Wrap"
                               IsVisible="{Binding BlockedSummary, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
                <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="120" Height="4"
                             VerticalAlignment="Center"
                             IsVisible="{Binding IsBusy}"/>
            </Grid>

            <SelectableTextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" Foreground="Gray"
                       FontSize="11" Margin="2,8,2,0" TextWrapping="Wrap"/>

            <!-- Sortable column headers. Column widths mirror the row template below (Auto,2*,3*,Auto,Auto
                 with the icon/size/modified columns pinned to 32/80/130) so captions line up over their data.
                 Clicking a header sorts by that column; clicking it again flips the direction. -->
            <Border DockPanel.Dock="Top" Padding="8,0" Margin="0,4,0,2"
                    BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="0,0,0,1">
                <Border.Styles>
                    <Style Selector="Button.colHeader">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="2,4"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Foreground" Value="Gray"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="Cursor" Value="Hand"/>
                    </Style>
                    <Style Selector="Button.colHeader:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                    </Style>
                </Border.Styles>
                <Grid ColumnDefinitions="Auto,2*,3*,Auto,Auto">
                    <Button Grid.Column="0" Width="32" Margin="0,0,8,0" Classes="colHeader"
                            HorizontalContentAlignment="Center"
                            Command="{Binding SortByCommand}" CommandParameter="Extension"
                            ToolTip.Tip="Sort by file type / extension">
                        <StackPanel Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                            <mi:MaterialIcon Kind="SortAlphabeticalVariant" Width="14" Height="14"/>
                            <TextBlock Text="{Binding ExtensionIndicator}" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Classes="colHeader"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Command="{Binding SortByCommand}" CommandParameter="Name"
                            Content="{Binding NameHeader}"/>
                    <Button Grid.Column="2" Classes="colHeader"
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Command="{Binding SortByCommand}" CommandParameter="Path"
                            Content="{Binding PathHeader}"/>
                    <Button Grid.Column="3" Width="80" Classes="colHeader"
                            HorizontalContentAlignment="Right"
                            Command="{Binding SortByCommand}" CommandParameter="Size"
                            Content="{Binding SizeHeader}"/>
                    <Button Grid.Column="4" Width="130" Classes="colHeader"
                            HorizontalContentAlignment="Right"
                            Command="{Binding SortByCommand}" CommandParameter="Modified"
                            Content="{Binding ModifiedHeader}"/>
                </Grid>
            </Border>

            <ListBox x:Name="ResultsList" ItemsSource="{Binding Results}"
                     DoubleTapped="OnResultDoubleTapped">
                <ListBox.Styles>
                    <!-- Zero the item's horizontal padding and match the header's 8px inset so the row grid
                         starts at the same x as the header grid. -->
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="8,0"/>
                        <Setter Property="MinHeight" Value="0"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchResultViewModel">
                        <!-- Background="Transparent" so the whole row is hit-testable for the right-click;
                             a Grid with no background ignores clicks on its empty areas. -->
                        <Grid ColumnDefinitions="Auto,2*,3*,Auto,Auto" Height="40" Background="Transparent">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open" Click="OnOpenResult"/>
                                    <MenuItem Header="Reveal in Explorer" Click="OnRevealResult"/>
                                    <Separator/>
                                    <MenuItem Header="Block subfolder">
                                        <MenuItem Header="From this search…"
                                                  Click="OnBlockSubfolderThisSearch"/>
                                        <MenuItem Header="From all searches…"
                                                  Click="OnBlockSubfolderAllSearches"/>
                                    </MenuItem>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Panel Grid.Column="0" Width="40" Margin="0,0,8,0" VerticalAlignment="Center"
                                   Background="Transparent"
                                   ToolTip.ServiceEnabled="{Binding HasPreview}"
                                   ToolTip.ShowDelay="300">
                                <ToolTip.Tip>
                                    <!-- Enlarged preview floating over the page; Preview shows the small
                                         thumb until the sharper decode lands, then rebinds. -->
                                    <Image Source="{Binding Preview}" MaxWidth="256" MaxHeight="256"
                                           Stretch="Uniform"/>
                                </ToolTip.Tip>
                                <!-- Image thumbnails fill the row height (ImageSize=40); shell icons stay
                                     compact (ImageSize=32) and centre in the fixed-width column. -->
                                <Image Width="{Binding ImageSize}" Height="{Binding ImageSize}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Source="{Binding Image}"
                                       IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <SelectableTextBlock Text="{Binding Kind}" VerticalAlignment="Center"
                                           HorizontalAlignment="Center"
                                           IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}"/>
                            </Panel>
                            <SelectableTextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <SelectableTextBlock Grid.Column="2" Text="{Binding FullPath}" Foreground="Gray"
                                       FontSize="11" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <SelectableTextBlock Grid.Column="3" Text="{Binding FormattedSize}" Foreground="Gray"
                                       FontSize="11" Width="80" TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                            <SelectableTextBlock Grid.Column="4" Text="{Binding Modified}" Foreground="Gray"
                                       FontSize="11" Width="130" TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
        </Grid>
    </DockPanel>
</Window>
