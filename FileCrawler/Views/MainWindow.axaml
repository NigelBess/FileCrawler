<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FileCrawler.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="620"
        x:Class="FileCrawler.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/app-icon.ico"
        Width="1000" Height="620"
        WindowState="Maximized"
        Title="FileCrawler — Fast File Search">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="300,*">

        <!-- Left: watched folders -->
        <DockPanel Grid.Column="0" Background="{DynamicResource SystemControlBackgroundListLowBrush}">
            <StackPanel DockPanel.Dock="Top" Margin="12,12,12,6" Spacing="8">
                <TextBlock Text="Watched Folders" FontWeight="SemiBold" FontSize="15"/>
                <Button Content="＋ Add folder…" HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Command="{Binding AddFolderCommand}"/>
            </StackPanel>

            <TextBlock DockPanel.Dock="Bottom" Margin="12,6,12,12" FontSize="11"
                       Foreground="Gray" TextWrapping="Wrap"
                       IsVisible="{Binding !WatchedFolders.Count}"
                       Text="No folders yet. Add a folder to crawl and search it."/>

            <ListBox ItemsSource="{Binding WatchedFolders}" Margin="6,0,6,0"
                     Background="Transparent">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:WatchedFolderViewModel">
                        <Border Padding="6" CornerRadius="4">
                            <StackPanel Spacing="2">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip.Tip="{Binding Path}"/>
                                <TextBlock Text="{Binding Path}" FontSize="10" Foreground="Gray"
                                           TextTrimming="CharacterEllipsis"/>
                                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                    <TextBlock Text="{Binding FormattedSize}" FontSize="11" Foreground="Gray"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Status}" FontSize="11" Foreground="#3B82F6"
                                               VerticalAlignment="Center"/>
                                    <Button Content="Refresh" FontSize="11" Padding="6,2"
                                            Click="OnRefreshFolder"
                                            IsEnabled="{Binding !IsBusy}"/>
                                    <Button Content="Remove" FontSize="11" Padding="6,2"
                                            Click="OnRemoveFolder"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Right: search + results -->
        <DockPanel Grid.Column="1" Margin="12">
            <TextBox DockPanel.Dock="Top" PlaceholderText="Search files and folders…"
                     FontSize="16" Text="{Binding SearchText}"/>

            <Expander DockPanel.Dock="Top" Margin="0,8,0,0" MinHeight="0"
                      HorizontalAlignment="Stretch"
                      IsExpanded="{Binding Filters.IsExpanded}">
                <Expander.Header>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Filters" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Filters.ActiveSummary}" Foreground="#3B82F6"
                                   FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Expander.Header>

                <StackPanel Spacing="10" Margin="4">
                    <!-- File-type categories: tri-state checkbox + per-extension flyout -->
                    <ItemsControl ItemsSource="{Binding Filters.Categories}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:FileCategoryViewModel">
                                <StackPanel Orientation="Horizontal" Margin="0,0,14,4">
                                    <CheckBox Content="{Binding Name}" IsThreeState="False"
                                              IsChecked="{Binding IsChecked}"/>
                                    <Button Padding="5,6" Margin="2,0,0,0"
                                            Background="Transparent" VerticalAlignment="Center"
                                            ToolTip.Tip="Choose specific extensions">
                                        <Path Data="M 0 0 L 8 0 L 4 5 Z" Fill="Gray"
                                              VerticalAlignment="Center"/>
                                        <Button.Flyout>
                                            <Flyout>
                                                <ScrollViewer MaxHeight="240">
                                                    <ItemsControl ItemsSource="{Binding Extensions}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="vm:ExtensionOptionViewModel">
                                                                <CheckBox Content="{Binding Name}"
                                                                          IsChecked="{Binding IsSelected}"/>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </ScrollViewer>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Custom extensions -->
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Other extensions:" VerticalAlignment="Center"/>
                        <TextBox Width="220" PlaceholderText=".psd .blend …"
                                 Text="{Binding Filters.CustomExtensionsText}"/>
                    </StackPanel>

                    <!-- Size / date / kind / clear -->
                    <WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,20,4">
                            <TextBlock Text="Size:" VerticalAlignment="Center"/>
                            <TextBox Width="70" PlaceholderText="min" Text="{Binding Filters.MinSizeText}"/>
                            <ComboBox ItemsSource="{x:Static vm:SearchFiltersViewModel.SizeUnits}"
                                      SelectedItem="{Binding Filters.MinSizeUnit}"/>
                            <TextBlock Text="–" VerticalAlignment="Center"/>
                            <TextBox Width="70" PlaceholderText="max" Text="{Binding Filters.MaxSizeText}"/>
                            <ComboBox ItemsSource="{x:Static vm:SearchFiltersViewModel.SizeUnits}"
                                      SelectedItem="{Binding Filters.MaxSizeUnit}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,20,4">
                            <TextBlock Text="Modified:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{x:Static vm:SearchFiltersViewModel.DatePresetOptions}"
                                      SelectedItem="{Binding Filters.SelectedDatePreset}"/>
                            <CalendarDatePicker SelectedDate="{Binding Filters.CustomFromDate}"
                                                PlaceholderText="from" IsVisible="{Binding Filters.IsCustomDate}"/>
                            <CalendarDatePicker SelectedDate="{Binding Filters.CustomToDate}"
                                                PlaceholderText="to" IsVisible="{Binding Filters.IsCustomDate}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,20,4">
                            <TextBlock Text="Show:" VerticalAlignment="Center"/>
                            <ComboBox ItemsSource="{x:Static vm:SearchFiltersViewModel.KindOptions}"
                                      SelectedItem="{Binding Filters.SelectedKind}"/>
                        </StackPanel>
                        <Button Content="Clear filters" Command="{Binding Filters.ClearFiltersCommand}"
                                IsEnabled="{Binding Filters.HasActiveFilters}"/>
                    </WrapPanel>

                    <TextBlock Text="{Binding Filters.ValidationMessage}" Foreground="#DC2626" FontSize="11"
                               IsVisible="{Binding Filters.ValidationMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                </StackPanel>
            </Expander>

            <Grid DockPanel.Dock="Top" Margin="2,8,2,8" ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding ResultsSummary}" Foreground="Gray"
                           VerticalAlignment="Center"/>
                <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="120" Height="4"
                             IsVisible="{Binding IsBusy}"/>
            </Grid>

            <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}" Foreground="Gray"
                       FontSize="11" Margin="2,8,2,0" TextWrapping="Wrap"/>

            <ListBox x:Name="ResultsList" ItemsSource="{Binding Results}"
                     DoubleTapped="OnResultDoubleTapped">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:SearchResultViewModel">
                        <Grid ColumnDefinitions="Auto,2*,3*,Auto,Auto" Height="40">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open" Click="OnOpenResult"/>
                                    <MenuItem Header="Reveal in Explorer" Click="OnRevealResult"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                            <Panel Grid.Column="0" Width="32" Margin="0,0,8,0" VerticalAlignment="Center">
                                <Image Width="32" Height="32" Source="{Binding Image}"
                                       IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                <TextBlock Text="{Binding Kind}" VerticalAlignment="Center"
                                           IsVisible="{Binding Image, Converter={x:Static ObjectConverters.IsNull}}"/>
                            </Panel>
                            <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="2" Text="{Binding FullPath}" Foreground="Gray"
                                       FontSize="11" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Column="3" Text="{Binding FormattedSize}" Foreground="Gray"
                                       FontSize="11" Width="80" TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding Modified}" Foreground="Gray"
                                       FontSize="11" Width="130" TextAlignment="Right"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</Window>
