<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="FileCrawler.Views.SettingsDialog"
        Icon="/Assets/app-icon.ico"
        Width="440" SizeToContent="Height"
        MaxHeight="520"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Title="Settings">

    <DockPanel Margin="16">

        <Grid DockPanel.Dock="Top" Margin="0,0,0,14" ColumnDefinitions="Auto,*">
            <mi:MaterialIcon Grid.Column="0" Kind="Cog" Width="22" Height="22"
                             VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Grid.Column="1" Text="Settings" FontWeight="SemiBold" FontSize="15"
                       VerticalAlignment="Center"/>
        </Grid>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8" Margin="0,20,0,0">
            <Button x:Name="CancelButton" Content="Cancel" Padding="14,6" Click="OnCancel"/>
            <Button x:Name="SaveButton" Content="Save" Padding="14,6" Classes="accent" Click="OnSave"/>
        </StackPanel>

        <StackPanel Spacing="6">
            <TextBlock Text="Maximum crawl time per folder" FontWeight="SemiBold"/>
            <TextBlock Foreground="Gray" FontSize="11" TextWrapping="Wrap"
                       Text="If a folder isn't fully indexed within this time, crawling stops and keeps whatever was found. You'll be warned and offered a one-click way to block the large subfolder that's slowing it down. Set to 0 for no limit."/>
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                <NumericUpDown x:Name="MaxCrawlSecondsInput"
                               Minimum="0" Maximum="600" Increment="1" Width="130"
                               FormatString="0"/>
                <TextBlock Text="seconds" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

    </DockPanel>
</Window>
